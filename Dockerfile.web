# Web (Next.js) service image (build context = repo root).
# syntax=docker/dockerfile:1
FROM node:22-slim AS base
WORKDIR /app

FROM base AS deps
COPY package.json package-lock.json ./
COPY apps/api/package.json apps/api/package.json
COPY apps/web/package.json apps/web/package.json
RUN npm ci

FROM base AS build
# The API origin is inlined into the client bundle at build time.
ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
COPY --from=deps /app/node_modules ./node_modules
COPY . .
# This app ships no static assets, so apps/web/public may not exist. Ensure it
# does so the runner stage's COPY of it doesn't fail the build.
RUN mkdir -p apps/web/public
RUN npm run build -w apps/web

FROM base AS runner
ENV NODE_ENV=production
ENV PORT=3000
# Next standalone output: server + only the node_modules it traced.
COPY --from=build /app/apps/web/.next/standalone ./
COPY --from=build /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=build /app/apps/web/public ./apps/web/public
EXPOSE 3000
CMD ["node", "apps/web/server.js"]
