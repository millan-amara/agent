# Web (Next.js) service image (build context = repo root).
# syntax=docker/dockerfile:1
FROM node:22-slim AS base
WORKDIR /app

FROM base AS deps
COPY package.json package-lock.json ./
COPY apps/api/package.json apps/api/package.json
COPY apps/web/package.json apps/web/package.json
RUN npm ci

FROM base AS build
# NEXT_PUBLIC_* values are inlined into the client bundle at build time, so they
# must be present as ARGs during `next build` — not just at runtime. Railway (and
# most platforms) passes service variables as build args to the matching ARG.
ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
# Meta Embedded Signup: the WhatsApp connect button renders only when both are set.
ARG NEXT_PUBLIC_META_APP_ID
ENV NEXT_PUBLIC_META_APP_ID=${NEXT_PUBLIC_META_APP_ID}
ARG NEXT_PUBLIC_META_CONFIG_ID
ENV NEXT_PUBLIC_META_CONFIG_ID=${NEXT_PUBLIC_META_CONFIG_ID}
COPY --from=deps /app/node_modules ./node_modules
COPY . .
# This app ships no static assets, so apps/web/public may not exist. Ensure it
# does so the runner stage's COPY of it doesn't fail the build.
RUN mkdir -p apps/web/public
RUN npm run build -w apps/web

FROM base AS runner
ENV NODE_ENV=production
ENV PORT=3000
# Next's standalone server defaults to binding localhost, which Railway's edge
# can't reach ("Application failed to respond"). Bind all interfaces.
ENV HOSTNAME=0.0.0.0
# Next standalone output: server + only the node_modules it traced.
COPY --from=build /app/apps/web/.next/standalone ./
COPY --from=build /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=build /app/apps/web/public ./apps/web/public
EXPOSE 3000
# Drop root — the standalone server only reads its own (world-readable) bundle.
USER node
CMD ["node", "apps/web/server.js"]
