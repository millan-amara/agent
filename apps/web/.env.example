# API origin the dashboard talks to (inlined at build time).
NEXT_PUBLIC_API_URL="http://localhost:3001"

# v2 Embedded Signup — Meta app + Embedded Signup config id (public).
# When both are set, the one-click "Connect WhatsApp" button appears; otherwise
# the manual paste flow is used. Requires Meta Tech Provider approval to run.
NEXT_PUBLIC_META_APP_ID=""
NEXT_PUBLIC_META_CONFIG_ID=""
