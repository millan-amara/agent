// Dev runs on SQLite (zero local services). Production target is Postgres —
// the schema deliberately avoids SQLite-only or Postgres-only features so the
// switch is a datasource swap + migration. Enums are strings for the same reason.

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Tenant {
  id              String   @id @default(cuid())
  name            String
  vertical        String   @default("general")
  onboarded       Boolean  @default(false)
  // JSON: { description, services: [{name, price}], faqs: [{q, a}], tone,
  //         languages, neverSay: [], bookingInfo, businessHours }
  businessProfile String
  // JSON array of pipeline stage names, first = default for new leads
  stages          String
  aiEnabled       Boolean  @default(true)
  waPhoneNumberId String?
  // Per-tenant Cloud API token (their WABA). Null = fall back to env (dev).
  waAccessToken   String?
  // WhatsApp Business Account ID — needed for template submission/status.
  waWabaId        String?
  // JSON: { enabled, delaysHours: number[], templateId } — auto no-reply sequences
  followUpConfig  String   @default("{}")
  // JSON: { enabled, slotMinutes, daysAhead, hours: {"1": {start,end}, ...} } (0=Sun..6=Sat)
  bookingConfig   String   @default("{}")
  // Tenant's own Paystack secret key — enables in-chat payment collection
  paystackSecretKey String?
  // Azayon subscription state. Pilot phase: trial only, no enforcement.
  plan            String   @default("trial") // trial | active | past_due
  trialEndsAt     DateTime?
  createdAt       DateTime @default(now())

  users        User[]
  contacts     Contact[]
  messages     Message[]
  followUps    FollowUp[]
  templates    Template[]
  appointments Appointment[]
  invoices     Invoice[]
  usage        Usage[]
}

// Per-tenant per-day LLM/message metering — the margin math behind pricing.
model Usage {
  id           String @id @default(cuid())
  tenantId     String
  day          String // "YYYY-MM-DD"
  inputTokens  Int    @default(0)
  outputTokens Int    @default(0)
  llmCalls     Int    @default(0)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, day])
}

model Appointment {
  id             String    @id @default(cuid())
  tenantId       String
  contactId      String
  startsAt       DateTime
  endsAt         DateTime
  status         String    @default("booked") // booked | cancelled | completed
  note           String    @default("")
  reminderSentAt DateTime?
  createdAt      DateTime  @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  contact Contact @relation(fields: [contactId], references: [id])

  @@index([tenantId, startsAt])
}

model Invoice {
  id          String    @id @default(cuid())
  tenantId    String
  contactId   String
  // KES subunits (cents) — Paystack convention
  amountCents Int
  description String
  status      String    @default("pending") // pending | paid | failed | cancelled
  paystackRef String    @unique
  payUrl      String
  paidAt      DateTime?
  createdAt   DateTime  @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  contact Contact @relation(fields: [contactId], references: [id])

  @@index([tenantId, status])
}

// WhatsApp template message (required for messaging outside the 24h window).
// Lifecycle: draft -> pending (submitted to Meta) -> approved | rejected.
model Template {
  id              String   @id @default(cuid())
  tenantId        String
  // Meta rules: lowercase letters, digits, underscores
  name            String
  language        String   @default("en")
  category        String   @default("UTILITY") // UTILITY | MARKETING
  // Body text; {{1}} = customer name, {{2}} = business name
  body            String
  status          String   @default("draft") // draft | pending | approved | rejected
  rejectionReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  tenantId     String
  createdAt    DateTime @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  sessions Session[]
}

model Session {
  token     String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Contact {
  id            String    @id @default(cuid())
  tenantId      String
  phone         String
  name          String?
  stage         String
  // JSON object of custom fields the AI captures during qualification
  fields        String    @default("{}")
  source        String?
  // Simulator contacts run the real agent loop but never touch WhatsApp
  isSimulated   Boolean   @default(false)
  aiPaused      Boolean   @default(false)
  optedOut      Boolean   @default(false)
  needsHuman    Boolean   @default(false)
  // Drives the 24h customer-service-window check for outbound sends
  lastInboundAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  messages     Message[]
  followUps    FollowUp[]
  appointments Appointment[]
  invoices     Invoice[]

  @@unique([tenantId, phone])
  @@index([tenantId, stage])
}

model Message {
  id          String   @id @default(cuid())
  tenantId    String
  contactId   String
  direction   String // "in" | "out"
  author      String // "customer" | "ai" | "human" | "system"
  kind        String   @default("text") // "text" | "event" (AI actions shown in timeline)
  text        String
  // Meta's wamid — unique so redelivered webhooks are idempotent
  waMessageId String?  @unique
  createdAt   DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  contact Contact @relation(fields: [contactId], references: [id])

  @@index([contactId, createdAt])
}

model FollowUp {
  id        String   @id @default(cuid())
  tenantId  String
  contactId String
  dueAt     DateTime
  note      String
  status    String   @default("scheduled") // scheduled | sent | skipped | canceled
  createdAt DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  contact Contact @relation(fields: [contactId], references: [id])

  @@index([status, dueAt])
}
