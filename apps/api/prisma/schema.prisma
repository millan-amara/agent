// Dev runs on SQLite (zero local services). Production target is Postgres —
// the schema deliberately avoids SQLite-only or Postgres-only features so the
// switch is a datasource swap + migration. Enums are strings for the same reason.

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Tenant {
  id              String   @id @default(cuid())
  name            String
  vertical        String   @default("general")
  onboarded       Boolean  @default(false)
  // JSON: { description, services: [{name, price}], faqs: [{q, a}], tone,
  //         languages, neverSay: [], bookingInfo, businessHours }
  businessProfile String
  // JSON array of pipeline stage names, first = default for new leads
  stages          String
  aiEnabled       Boolean  @default(true)
  waPhoneNumberId String?
  // Per-tenant Cloud API token (their WABA). Null = fall back to env (dev).
  waAccessToken   String?
  // WhatsApp Business Account ID — needed for template submission/status.
  waWabaId        String?
  // JSON: { enabled, delaysHours: number[], templateId } — auto no-reply sequences
  followUpConfig  String   @default("{}")
  // Owner morning digest (JSON: { enabled, hour, channel }). hour is the KE-local
  // hour (0-23) to send; channel = auto | whatsapp | email. The digest is the
  // AI's daily "here's what I did / what needs you" report.
  digestConfig    String   @default("{}")
  // The owner's own WhatsApp number (digits only). Single source of truth for
  // both digest delivery and owner chat. Legacy configs may still carry it in
  // digestConfig.ownerPhone; deliverDigest falls back to that.
  ownerPhone      String?
  // Owner chat: when on, a message from ownerPhone to the business number is
  // routed to the read-only owner assistant instead of the customer sales agent.
  ownerChatEnabled Boolean @default(false)
  // The business's dialable WhatsApp number (display_phone_number from Meta,
  // digits only), captured on connect. Powers the public page's wa.me link.
  waDisplayPhone  String?
  // Public business page: opt-in mini-site at APP_BASE_URL/b/<slug>.
  slug            String?  @unique
  publicEnabled   Boolean  @default(false)
  // JSON: { enabled, slotMinutes, daysAhead, hours: {"1": {start,end}, ...} } (0=Sun..6=Sat)
  bookingConfig   String   @default("{}")
  // Tenant's own Paystack secret key — enables in-chat payment collection
  paystackSecretKey String?
  // Invoice branding — shown on the public hosted invoice page (/i/<token>).
  logoUrl       String?
  businessPhone String?
  businessEmail String?
  // Free-text payment instructions for offline invoices (e.g. M-Pesa Till).
  payInstructions String?
  // Azayon subscription state. Pilot phase: trial only, no enforcement.
  plan            String   @default("trial") // trial | active | past_due
  trialEndsAt     DateTime?
  // WhatsApp health (Meta phone-number quality + messaging-limit tier),
  // refreshed from quality webhooks and a periodic Graph poll.
  waQualityRating   String?   // GREEN | YELLOW | RED | UNKNOWN
  waMessagingLimit  String?   // e.g. TIER_1K, TIER_10K, TIER_100K, TIER_UNLIMITED
  waQualityCheckedAt DateTime?
  // Outbound guardrails. Null = platform default applied in code.
  dailyMessageCap Int?     // max outbound messages per contact per day
  dataRetentionDays Int?   // null = keep forever; else retention sweep deletes older messages
  // Stakes-aware approval gate (JSON: { payments?: bool }). Empty = auto-apply
  // everything (legacy behavior). When payments=true the AI drafts an invoice as
  // pending_approval and an owner sends the link — money never leaves on a guess.
  requireApproval String  @default("{}")
  // Azayon subscription billing (platform Paystack account, not the tenant's).
  planTier               String?   // starter | growth | pro (null while on trial)
  paystackCustomerCode   String?
  paystackSubscriptionCode String?
  planRenewsAt           DateTime?
  // Set when the owner cancels: subscription renewal is stopped on Paystack but
  // access continues until planRenewsAt, when the lapse sweep flips to past_due.
  cancelAtPeriodEnd      Boolean  @default(false)
  // Trial-ending owner emails — timestamps so each fires at most once.
  trialEndingNoticeSentAt DateTime?
  trialEndedNoticeSentAt  DateTime?
  // Google Calendar sync (per-tenant OAuth).
  googleRefreshToken String?
  googleCalendarId   String?  @default("primary")
  // Monotonic per-tenant invoice counter — the source of human invoice numbers
  // (INV-0001, INV-0002, …). Incremented inside the create transaction.
  invoiceSeq      Int      @default(0)
  createdAt       DateTime @default(now())

  users        User[]
  contacts     Contact[]
  messages     Message[]
  followUps    FollowUp[]
  templates    Template[]
  appointments Appointment[]
  invoices     Invoice[]
  usage        Usage[]
  kbDocs       KbDoc[]
  kbChunks     KbChunk[]
  digests      DigestLog[]
  ownerMessages OwnerMessage[]
  auditLogs    AuditLog[]
  broadcasts   Broadcast[]
}

// Per-tenant per-day-per-model LLM/message metering — the margin math behind
// pricing. Split by model so the cheap router vs the reply model are costed
// separately (cost tiering).
model Usage {
  id       String @id @default(cuid())
  tenantId String
  day      String // "YYYY-MM-DD"
  model    String @default("") // the model id these tokens were spent on

  // Token classes are metered separately because they are billed at different
  // rates: a cache read costs 0.1x base input, a 5m write 1.25x, a 1h write 2x.
  // Lumping them into one figure (as this table used to) makes cached traffic
  // look 10x more expensive than it is and hides whether caching works at all.
  inputTokens        Int @default(0) // base input: neither cached nor cache-written
  outputTokens       Int @default(0)
  cacheWrite5mTokens Int @default(0)
  cacheWrite1hTokens Int @default(0)
  cacheReadTokens    Int @default(0)
  llmCalls           Int @default(0)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, day, model])
}

model Appointment {
  id             String    @id @default(cuid())
  tenantId       String
  contactId      String
  startsAt       DateTime
  endsAt         DateTime
  status         String    @default("booked") // booked | cancelled | completed
  note           String    @default("")
  reminderSentAt DateTime?
  googleEventId  String?   // set when synced to the tenant's Google Calendar
  createdAt      DateTime  @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  contact Contact @relation(fields: [contactId], references: [id])

  @@index([tenantId, startsAt])
}

model Invoice {
  id          String    @id @default(cuid())
  tenantId    String
  contactId   String
  // Human invoice number, unique per tenant (rendered as INV-0042). Allocated
  // from Tenant.invoiceSeq at create time.
  number      Int
  // Unguessable token for the public hosted invoice page (/i/<token>). Distinct
  // from the (sequential, enumerable) number and from paystackRef.
  publicToken String    @unique
  // KES subunits (cents) — Paystack convention. Grand total = sum(items) + tax.
  amountCents Int
  // Tax as a percentage of the subtotal (e.g. 16 for VAT). taxCents is the
  // materialized amount = round(subtotal * taxRate / 100), kept for accounting.
  taxRate     Float     @default(0)
  taxCents    Int       @default(0)
  currency    String    @default("KES")
  // Short title / summary of the invoice. For legacy single-amount invoices this
  // is the only descriptor; line-item invoices also carry it as a heading.
  description String
  notes       String?
  // draft (created, not issued) | pending_approval (AI proposed) |
  // pending (issued, awaiting payment) | paid | failed | cancelled
  status      String    @default("pending")
  paystackRef String    @unique
  // Null when no Paystack link has been minted — record-only invoices and
  // pending_approval invoices both have no link yet.
  payUrl      String?
  dueDate     DateTime?
  // When the invoice was issued/sent to the customer (null while draft).
  issuedAt    DateTime?
  paidAt      DateTime?
  // Paystack channel that settled the payment, captured from charge.success
  // (e.g. "mobile_money" for M-Pesa, "card"). Null until paid / for offline
  // payments. Can't be backfilled, so we record it at settlement time — the
  // M-Pesa-vs-card mix drives the wholesale-rate economics later.
  paymentMethod String?
  createdAt   DateTime  @default(now())

  tenant  Tenant        @relation(fields: [tenantId], references: [id])
  contact Contact       @relation(fields: [contactId], references: [id])
  items   InvoiceItem[]

  @@unique([tenantId, number])
  @@index([tenantId, status])
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Int     @default(1)
  // KES subunits (cents) per unit. Line total = quantity * unitCents.
  unitCents   Int

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// WhatsApp template message (required for messaging outside the 24h window).
// Lifecycle: draft -> pending (submitted to Meta) -> approved | rejected.
model Template {
  id              String   @id @default(cuid())
  tenantId        String
  // Meta rules: lowercase letters, digits, underscores
  name            String
  language        String   @default("en")
  category        String   @default("UTILITY") // UTILITY | MARKETING
  // Body text; {{1}} = customer name, {{2}} = business name
  body            String
  status          String   @default("draft") // draft | pending | approved | rejected
  rejectionReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  name          String?
  phone         String?  // carried over from the legacy CRM; informational
  emailVerified Boolean  @default(false)
  role          String   @default("owner") // owner | agent
  locale        String   @default("en")    // en | sw
  tenantId      String
  createdAt     DateTime @default(now())

  tenant   Tenant      @relation(fields: [tenantId], references: [id])
  sessions Session[]
  authTokens AuthToken[]
  assignedContacts Contact[] @relation("AssignedAgent")
}

// Append-only activity trail for team accountability (assignments, takeovers,
// stage/plan/team changes). Owner-visible.
model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?
  action    String
  detail    String   @default("")
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
}

// One row per delivered owner morning digest. The @@unique([tenantId, day])
// is the idempotency guard — the insert itself claims the day, so a restarted
// or duplicated worker can never send two digests for the same KE calendar day.
model DigestLog {
  id        String   @id @default(cuid())
  tenantId  String
  day       String   // KE calendar day the digest was sent (YYYY-MM-DD)
  channel   String   // whatsapp | email
  status    String   @default("sent") // sent | failed
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, day])
}

// The owner's private chat with their business. Kept in its own table (not the
// customer Contact/Message tables) so owner traffic never touches lead stats,
// billing conversation counts, or the pipeline. Read-only assistant for now.
model OwnerMessage {
  id          String   @id @default(cuid())
  tenantId    String
  direction   String // "in" (owner) | "out" (assistant)
  text        String
  waMessageId String?  @unique // Meta wamid — unique so redelivered webhooks are idempotent
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
}

// A template campaign to a segment. Outside the 24h window only approved
// templates are legal, so a broadcast always sends an approved Template.
model Broadcast {
  id         String   @id @default(cuid())
  tenantId   String
  templateId String
  segment    String   @default("{}") // JSON: { stage?, source?, all? }
  status     String   @default("draft") // draft | sending | done | failed
  total      Int      @default(0)
  sent       Int      @default(0)
  failed     Int      @default(0)
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
}

// Single-use tokens for email-driven flows (password reset, email verification).
model AuthToken {
  token     String   @id
  userId    String
  purpose   String // reset | verify
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, purpose])
}

// Uploaded knowledge-base source (doc/FAQ paste). Chunked + embedded for RAG.
model KbDoc {
  id        String   @id @default(cuid())
  tenantId  String
  title     String
  source    String   @default("paste") // paste | upload
  status    String   @default("ready") // ready | processing | failed
  createdAt DateTime @default(now())

  tenant Tenant    @relation(fields: [tenantId], references: [id])
  chunks KbChunk[]

  @@index([tenantId])
}

// One embedded chunk of a KbDoc. embedding = JSON-encoded float array;
// retrieval is brute-force cosine in JS at pilot scale (pgvector later).
model KbChunk {
  id        String @id @default(cuid())
  tenantId  String
  docId     String
  ordinal   Int
  content   String
  embedding String // JSON number[]

  tenant Tenant @relation(fields: [tenantId], references: [id])
  doc    KbDoc  @relation(fields: [docId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([docId])
}

model Session {
  token     String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Contact {
  id            String    @id @default(cuid())
  tenantId      String
  phone         String
  name          String?
  stage         String
  // NB: there is deliberately no stored "pipeline value" here. Open value is
  // derived from unpaid invoices (see ownerTools.pipeline_breakdown) so it can
  // never drift from the money actually billed.
  // JSON object of custom fields the AI captures during qualification
  fields        String    @default("{}")
  source        String?
  // Team assignment — which staff member owns this conversation.
  assignedUserId String?
  // Simulator contacts run the real agent loop but never touch WhatsApp
  isSimulated   Boolean   @default(false)
  aiPaused      Boolean   @default(false)
  optedOut      Boolean   @default(false)
  needsHuman    Boolean   @default(false)
  // Set when an agent turn failed (AI down / threw). The raw inbound is already
  // saved; this flags "the net caught it but the AI couldn't process it" so the
  // owner sees it instead of the customer being silently ghosted.
  needsReview   Boolean   @default(false)
  // Drives the 24h customer-service-window check for outbound sends
  lastInboundAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  assignedUser User?         @relation("AssignedAgent", fields: [assignedUserId], references: [id])
  messages     Message[]
  followUps    FollowUp[]
  appointments Appointment[]
  invoices     Invoice[]

  @@unique([tenantId, phone])
  @@index([tenantId, stage])
}

model Message {
  id          String   @id @default(cuid())
  tenantId    String
  contactId   String
  direction   String // "in" | "out"
  author      String // "customer" | "ai" | "human" | "system"
  kind        String   @default("text") // "text" | "event" (AI actions shown in timeline)
  text        String
  // Meta's wamid — unique so redelivered webhooks are idempotent. Also set on
  // outbound sends so delivery-status webhooks can be correlated back.
  waMessageId String?  @unique
  // Outbound delivery lifecycle from Meta status webhooks.
  status       String? // sent | delivered | read | failed
  statusReason String? // failure detail when status = failed
  // The channel this message arrived/left on. WhatsApp today; the pipeline keeps
  // this seam so email/meetings can emit the same normalized shape later.
  channel     String   @default("whatsapp") // whatsapp | email | meeting
  // Inbound media (voice notes, images). text holds the transcript/caption.
  mediaType   String?  // audio | image | document | ...
  mediaUrl    String?  // Meta media id or stored URL for the original
  createdAt   DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  contact Contact @relation(fields: [contactId], references: [id])

  @@index([contactId, createdAt])
}

model FollowUp {
  id        String   @id @default(cuid())
  tenantId  String
  contactId String
  dueAt     DateTime
  note      String
  status    String   @default("scheduled") // scheduled | sent | skipped | canceled
  createdAt DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  contact Contact @relation(fields: [contactId], references: [id])

  @@index([status, dueAt])
}
