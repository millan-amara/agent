# --- Required ---
DATABASE_URL="file:./dev.db"
ANTHROPIC_API_KEY=""

# --- WhatsApp Cloud API (leave empty to run simulator-only) ---
WA_ACCESS_TOKEN=""
WA_PHONE_NUMBER_ID=""
# Any string you choose; must match what you enter in the Meta webhook config UI
WA_VERIFY_TOKEN="azayon-dev-verify"
# Meta App secret, used to verify X-Hub-Signature-256 on incoming webhooks
WA_APP_SECRET=""
# WhatsApp Business Account ID (template submission/status)
WA_WABA_ID=""

# --- Models (cost tiers) ---
REPLY_MODEL="claude-opus-4-8"
ROUTER_MODEL="claude-haiku-4-5"

# --- Server ---
PORT=3001
# Seconds of customer silence before the AI replies (batches rapid-fire messages)
DEBOUNCE_SECONDS=5

# --- Production infra (leave empty for the in-process dev path) ---
# Set in production (Railway add-on). Presence switches the queue to BullMQ and
# the event bus to Redis pub/sub. In prod DATABASE_URL is a postgresql:// URL.
REDIS_URL=""
# Error monitoring (no-op when empty)
SENTRY_DSN=""
# Comma-separated allow-list of web origins for CORS in prod (empty = permissive)
WEB_ORIGIN=""
# Public URL of the web app — used to build email links (password reset/verify)
APP_BASE_URL="http://localhost:3000"

# --- External providers (features degrade gracefully when unset) ---
# Voice-note transcription (Groq whisper-large-v3)
GROQ_API_KEY=""
# Knowledge-base embeddings (Voyage AI)
VOYAGE_API_KEY=""
# Transactional email (Resend) for password reset + verification + alerts
RESEND_API_KEY=""
EMAIL_FROM="Azayon <onboarding@azayon.app>"

# --- Internal cost dashboard ---
# Set to enable GET /api/admin/costs (send header x-admin-token). Leave empty to disable.
ADMIN_TOKEN=""
# At-rest encryption key for per-tenant secrets (WhatsApp/Paystack/Google creds).
# Any high-entropy string (e.g. `openssl rand -hex 32`). REQUIRED in production.
# Changing it makes existing encrypted secrets unreadable — set once and keep safe.
SECRETS_ENCRYPTION_KEY=""
# Rough USD→KES rate for internal cost reporting
USD_TO_KES=130

# --- v2 Billing: Azayon's OWN Paystack account for subscriptions (NOT the
# tenant's key). Create 3 subscription Plans in that account and paste the codes. ---

# --- v2 Embedded Signup (Meta Tech Provider). Public ids also go in apps/web. ---
META_APP_ID=""
META_APP_SECRET=""
META_CONFIG_ID=""

# --- v2 Google Calendar sync (per-tenant OAuth) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3001/api/integrations/google/callback"
