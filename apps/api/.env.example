# --- Required ---
DATABASE_URL="file:./dev.db"
ANTHROPIC_API_KEY=""

# --- WhatsApp Cloud API (leave empty to run simulator-only) ---
WA_ACCESS_TOKEN=""
WA_PHONE_NUMBER_ID=""
# Any string you choose; must match what you enter in the Meta webhook config UI
WA_VERIFY_TOKEN="azayon-dev-verify"
# Meta App secret, used to verify X-Hub-Signature-256 on incoming webhooks
WA_APP_SECRET=""

# --- Models (cost tiers) ---
REPLY_MODEL="claude-opus-4-8"
ROUTER_MODEL="claude-haiku-4-5"

# --- Server ---
PORT=3001
# Seconds of customer silence before the AI replies (batches rapid-fire messages)
DEBOUNCE_SECONDS=5
